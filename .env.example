# =============================================================================
# Environment Variables — TEMPLATE
# Copy to .env and set all values before running docker-compose or local dev.
# NEVER commit the .env file to Git.
# =============================================================================

# --- Snowflake ---
SNOWFLAKE_ACCOUNT=<your_snowflake_account>
SNOWFLAKE_USER=<your_snowflake_user>
SNOWFLAKE_PASSWORD=<your_snowflake_password>
SNOWFLAKE_DATABASE=CLV_CROSS_SELL
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=CLV_API_READER

# --- Databricks ---
DATABRICKS_HOST=<your_databricks_host>
DATABRICKS_TOKEN=<your_databricks_token>

# --- Azure ---
AZURE_SUBSCRIPTION_ID=<your_azure_subscription_id>
AZURE_TENANT_ID=<your_azure_tenant_id>

# --- API Security (VULN-010) ---
# Set this to enable JWT authentication. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
API_SECRET_KEY=

# --- CORS (VULN-005) ---
CORS_ALLOWED_ORIGINS=http://localhost:8501,http://dashboard:8501

# --- Infrastructure Passwords (VULN-008) ---
# Generate strong passwords with: python -c "import secrets; print(secrets.token_urlsafe(24))"
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=<generate_strong_password>
AIRFLOW_POSTGRES_DB=airflow
AIRFLOW_ADMIN_PASSWORD=<generate_strong_password>
GRAFANA_ADMIN_PASSWORD=<generate_strong_password>
PGADMIN_EMAIL=admin@yourcompany.com
PGADMIN_PASSWORD=<generate_strong_password>
